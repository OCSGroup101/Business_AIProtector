# OpenClaw — Environment Variables Example
# Copy to .env and adjust for your dev environment.
# NEVER commit .env to version control.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=openclaw_dev_password

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=openclaw_dev_redis

# ─── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=keycloak_admin_dev

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=openclaw_minio
MINIO_ROOT_PASSWORD=openclaw_minio_dev

# ─── Kong ────────────────────────────────────────────────────────────────────
KONG_DB_PASSWORD=kong_dev_password

# ─── Platform API ────────────────────────────────────────────────────────────
SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ─── Dev mode (local development only — NEVER set in production) ──────────────
# Bypasses Keycloak JWT auth (RBAC grants tenant_admin) and tenant middleware
# (uses OPENCLAW_DEV_TENANT_ID instead of JWT claim).
OPENCLAW_DEV_MODE=true
OPENCLAW_DEV_TENANT_ID=dev
OPENCLAW_ADMIN_TOKEN=dev-admin-token

# ─── Claude API (for assistant features) ─────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Signing (CI only — do not set in dev) ───────────────────────────────────
# MINISIGN_SECRET_KEY=  # CI secret, not used locally
