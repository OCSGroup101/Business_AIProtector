FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt requirements-dev.txt ./
RUN pip install --no-cache-dir -r requirements-dev.txt

# Copy source (overridden by volume mount in docker-compose dev mode)
COPY . .

EXPOSE 8888

# Uvicorn with hot reload.
# --app-dir / adds / to sys.path so that /app is importable as the "app"
# package, enabling relative imports (from . import pki) in app/main.py.
# Without this, uvicorn imports "main" as a top-level module (__package__=""),
# causing ImportError: attempted relative import with no known parent package.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8888", "--reload", "--reload-dir", "/app", "--log-level", "debug", "--app-dir", "/"]
